{
  "name": "calendit",
  "version": "1.0.2",
  "description": "Terminal-based calendar management tool for Google Calendar and Outlook via CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "calendit": "bin/cli.js"
  },
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "prepare": "npm run build",
    "test": "node --loader ts-node/esm src/test_runner.ts"
  },
  "keywords": [
    "calendar",
    "google-calendar",
    "outlook",
    "microsoft-graph",
    "cli",
    "terminal",
    "productivity"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chromatribe/calendit.git"
  },
  "homepage": "https://github.com/chromatribe/calendit#readme",
  "bugs": {
    "url": "https://github.com/chromatribe/calendit/issues"
  },
  "author": "chromatribe - s.ohara <ivis.klain@chromatri.be>",
  "license": "ISC",
  "dependencies": {
    "@azure/msal-node": "^3.8.10",
    "@azure/msal-node-extensions": "^1.5.32",
    "commander": "^12.1.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "enquirer": "^2.4.1",
    "googleapis": "^171.4.0",
    "open": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
